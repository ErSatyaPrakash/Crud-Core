@model Crud_Core.Models.Employee

<style>
    /* Page-scoped styles for Edit Employee view */
    #edit-employee {
        max-width: 760px;
        margin: 32px auto;
        padding: 0 12px;
    }

        #edit-employee .card {
            border: 0;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(18, 38, 63, 0.08);
            overflow: hidden;
        }

        #edit-employee .card-header {
            background: linear-gradient(90deg, #0d6efd 0%, #0b5ed7 100%);
            color: #fff;
            padding: 16px 20px;
            font-weight: 600;
            font-size: 1.05rem;
        }

        #edit-employee .card-body {
            background: #fff;
            padding: 22px;
        }

        #edit-employee label {
            font-weight: 600;
            color: #243447;
            display: block;
            margin-bottom: 6px;
        }

        #edit-employee .form-control {
            border-radius: 8px;
            border: 1px solid #d7e1ec;
            padding: 10px 12px;
            transition: box-shadow .12s ease, border-color .12s ease;
        }

            #edit-employee .form-control:focus {
                outline: none;
                border-color: #4f9cff;
                box-shadow: 0 6px 18px rgba(79,156,255,0.12);
            }

        /* nicer select arrow (keeps native behavior) */
        #edit-employee select.form-control {
            appearance: none;
            -webkit-appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='%23666' viewBox='0 0 16 16'><path d='M3.204 5h9.592L8 10.481 3.204 5z'/></svg>");
            background-repeat: no-repeat;
            background-position: right 12px center;
            padding-right: 40px;
        }

        #edit-employee .mb-3 {
            margin-bottom: 16px;
        }

        #edit-employee .btn-primary {
            border-radius: 8px;
            padding: 10px 18px;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(11, 92, 183, 0.12);
            border: none;
            background: linear-gradient(90deg,#0b5ed7,#0a58ca);
        }

    /* responsive */
    @@media (max-width: 576px) {
        #edit-employee {
            padding: 0 8px;
        }

            #edit-employee .card-body {
                padding: 16px;
            }
    }
</style>

<div id="edit-employee">
    <div class="card">
        <div class="card-header">Edit Employee</div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="id" />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <input asp-for="Role" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Country</label>
                    <select asp-for="CountryId" id="ddlCountry" class="form-control">
                        <option value="">Select Country</option>

                        @foreach (var item in ViewBag.Countries)
                        {
                            <option value="@item.CountryId">
                                @item.CountryName
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">State</label>
                    <select asp-for="StateId" id="ddlState" class="form-control">
                        <option value="">Select State</option>

                        @foreach (var item in ViewBag.States)
                        {
                            <option value="@item.StateId">
                                @item.StateName
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">City</label>
                    <select asp-for="CityId" id="ddlCity" class="form-control">
                        <option value="">Select City</option>

                        @foreach (var item in ViewBag.Cities)
                        {
                            <option value="@item.CityId">
                                @item.CityName
                            </option>
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">
                    Update
                </button>
            </form>
        </div>
    </div>
</div>


                        
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $("#ddlCountry").change(function () {

    var countryId = $(this).val();

    $.get('/Home/getstate',
    { id: countryId },
    function (data) {

    $("#ddlState").empty();

    $.each(data, function (i, item) {

    $("#ddlState").append(
    `<option value="${item.stateId}">
    ${item.stateName}
    </option>`);
    });

    });
    });


    $("#ddlState").change(function () {

    var stateId = $(this).val();

    $.get('/Home/getcity',
    { id: stateId },
    function (data) {

    $("#ddlCity").empty();

    $.each(data, function (i, item) {

    $("#ddlCity").append(
    `<option value="${item.cityId}">
    ${item.cityName}
    </option>`);
    });

    });
    });
</script>
